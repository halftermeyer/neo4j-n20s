# Copy to .env (gitignored) — the notebook loads it via python-dotenv.
# With NEO4J_* set, projections fetch rows over Bolt using the scoping Cypher;
# without, the notebook uses identical inline rows.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j
N20S_URL=http://localhost:7475
